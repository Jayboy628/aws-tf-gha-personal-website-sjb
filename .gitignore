# Terraform working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Terraform plan files
*.tfplan
tfplan

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Keep example variable files
!*.tfvars.example

# macOS
.DS_Store
